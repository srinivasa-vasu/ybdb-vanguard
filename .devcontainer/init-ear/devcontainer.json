{
  "name": "Encryption at Rest (EAR)",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-ear",
    "SCRIPT_PATH": "init-ear",
    // yb-admin master address for all EAR commands
    "MASTERS": "127.0.0.1:7100",
    // Directory where key files are stored during the exercise
    "KEY_DIR": "init-ear/keys"
  },
  "hostRequirements": {
    // EAR is a cluster-level feature; single node is sufficient for the exercise
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // One-time: install pv + demo-magic + openssl (for key generation)
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq pv openssl && curl -ssLo init-ear/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-ear/pscript init-ear/prompt.sh && mkdir -p init-ear/keys && echo \"✅ EAR exercise ready\"'",
  // Single-node cluster — EAR is enabled via yb-admin after startup, not a startup flag
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 1 && echo \"\" && echo \"▶  Terminal → Run Task → ear-demo   (guided EAR demo)\" && echo \"▶  Terminal → Run Task → ysql        (YSQL shell)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on"
      },
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": [
        {
          // Compound task: opens exercise-specific terminals when the workspace loads.
          // ysql opens separately via its own runOn:folderOpen in the workspace tasks.json.
          "label": "_auto-open",
          "type": "shell",
          "command": "code init-ear/README.md 2>/dev/null || true",
          "dependsOn": ["ear-demo"],
          "dependsOrder": "parallel",
          "runOptions": { "runOn": "folderOpen" },
          "presentation": { "reveal": "never", "panel": "shared" },
          "problemMatcher": []
        }
      ]
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
