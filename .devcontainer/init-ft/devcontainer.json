{
  "name": "Fault Tolerance & High Availability",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-ft",
    "SCRIPT_PATH": "init-ft",
    "HOST_LB":  "127.0.0.1",
    "HOST_LB2": "127.0.0.2",
    "HOST_LB3": "127.0.0.3",
    "HOST_LB4": "127.0.0.4",
    "HOST_LB5": "127.0.0.5",
    "HOST_LB6": "127.0.0.6",
    // load-generator credentials (used by yb-sample-apps.jar)
    "SECRET": "yugabyte",
    "YB_USER": "yugabyte",
    // bump this when a new yb-sample-apps release is available
    "YB_SAMPLE_APPS_VERSION": "1.4.1"
  },
  "hostRequirements": {
    // 8-core required: 6-node cluster + load generation + chaos experiments
    "cpus": 8,
    "memory": "16gb",
    "storage": "32gb"
  },
  "features": {
    // Java runtime for yb-sample-apps.jar load generator
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "jdkDistro": "ms"
    }
  },
  // One-time: install pv, download demo-magic + sample apps
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq pv && curl -ssLo init-ft/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-ft/pscript init-ft/prompt.sh && wget -q https://github.com/yugabyte/yb-sample-apps/releases/download/v${YB_SAMPLE_APPS_VERSION}/yb-sample-apps.jar && echo \"✅ FT exercise ready\"'",
  // Full 6-node cluster across 3 zones for chaos experiments
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 6 && echo \"\" && echo \"▶  Terminal → Run Task → ysql-load   (YSQL load generator)\" && echo \"▶  Terminal → Run Task → ycql-load   (YCQL load generator)\" && echo \"▶  Terminal → Run Task → az-fd        (chaos demo shell)\" && echo \"▶  Terminal → Run Task → ft: start all (launch all three at once)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "files.exclude": {
        "init-xcluster": true,
        "init-tablespace": true,
        "init-colocate": true,
        ".devcontainer": true,
        ".github": true,
        "init-cdc": true,
        "init-clone": true,
        "init-dsql": true,
        "init-ear": true,
        "init-geo": true,
        "init-obs": true,
        "init-pitr": true,
        "init-privacy": true,
        "init-qt": true,
        "init-rls": true,
        "init-scale": true,
        "init-tt": true,
        "init-voyager-mariadb": true,
        "init-voyager-mysql": true,
        "init-voyager-oracle": true,
        "init-voyager-postgres": true
        }},
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": []
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
