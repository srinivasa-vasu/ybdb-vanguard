{
  // ── Default Codespace configuration ──────────────────────────────────────
  // This is the "Distributed SQL Basics" exercise (init-dsql).
  // To launch a different exercise, use the devcontainer picker when creating
  // a new Codespace, or run: ./launch
  "name": "YugabyteDB · DSQL Basics (default)",
  "build": {
    "dockerfile": "../.ybdb.Dockerfile",
    "context": ".."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-dsql"
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // Start a 3-node zone-aware cluster on every Codespace resume
  "postStartCommand": "bash .devcontainer/scripts/start-ybdb.sh 3",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on"
      },
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": [
        {
          "label": "_auto-open",
          "type": "shell",
          "command": "code init-dsql/README.md 2>/dev/null || true",
          "runOptions": { "runOn": "folderOpen" },
          "presentation": { "reveal": "never", "panel": "shared" },
          "problemMatcher": []
        }
      ]
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
