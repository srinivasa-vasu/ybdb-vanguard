{
  "name": "Voyager — Oracle → YugabyteDB migration",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-voyager-oracle",
    "ORACLE_PASSWORD": "B3kind1!",
    "ORACLE_PDB": "legacy",
    "SRC_DB_TYPE": "oracle",
    "SRC_USER": "system",
    "SRC_SECRET": "B3kind1!",
    "TARGET_DB_ID": "yugabyte",
    "TARGET_USER": "yugabyte",
    "TARGET_SECRET": "yugabyte",
    "SCHEMA": "SYSTEM"
  },
  "hostRequirements": {
    // Oracle Free requires significant RAM; 8-core strongly recommended
    "cpus": 8,
    "memory": "16gb",
    "storage": "64gb"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  // One-time: pre-pull Oracle image (~4 GB — takes time!), install yb-voyager
  "postCreateCommand": "bash -c 'docker compose -f init-voyager-oracle/compose.yml pull && wget -q -O /tmp/yb-voyager https://raw.githubusercontent.com/yugabyte/yb-voyager/main/docker/yb-voyager-docker && chmod +x /tmp/yb-voyager && sudo mv /tmp/yb-voyager /usr/local/bin/yb-voyager && mkdir -p voyager-data && echo \"✅ Oracle Voyager exercise ready (Oracle image pre-pulled)\"'",
  // Every start: launch YugabyteDB + Oracle container
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 1 && docker compose -f init-voyager-oracle/compose.yml up -d && echo \"✅ YugabyteDB running. Oracle starting (may take 2-3 min to be ready on port 1521)\"'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000, 1521],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" },
    "1521":  { "label": "oracle",         "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
