{
  "name": "Colocation & Distributed Tables",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-colocate",
    "MASTERS": "127.0.0.1:7100,127.0.0.2:7100,127.0.0.3:7100"
  },
  "hostRequirements": {
    // 3-node cluster on a single machine; 4 CPUs is sufficient
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  // 3-node cluster so the tablet count difference (1 colocated vs 3 distributed) is visible
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 3 && echo \"\" && echo \"▶  Terminal → Run Task → colocate-demo   (guided colocation demo)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "files.exclude": {
        "ybdb": true,
        "voyager-data": true,
        "init-xcluster": true,
        "init-tablespace": true,
        ".devcontainer": true,
        ".github": true,
        "init-cdc": true,
        "init-clone": true,
        "init-dsql": true,
        "init-ear": true,
        "init-ft": true,
        "init-geo": true,
        "init-obs": true,
        "init-pitr": true,
        "init-privacy": true,
        "init-qt": true,
        "init-rls": true,
        "init-scale": true,
        "init-tt": true,
        "init-voyager-mariadb": true,
        "init-voyager-mysql": true,
        "init-voyager-oracle": true,
        "init-voyager-postgres": true
        }},
      "extensions": [],
      "tasks": []
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
