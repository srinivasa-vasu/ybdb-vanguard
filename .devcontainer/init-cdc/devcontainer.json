{
  "name": "Change Data Capture — YugabyteDB → PostgreSQL via Debezium",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-cdc",
    // YugabyteDB source connector version — bump when a new release is available at
    // https://github.com/yugabyte/debezium/releases
    "YBDB_CONNECTOR_VERSION": "dz.2.5.2.yb.2025.2.3",
    "KAFKA_CONNECT_PORT": "8083",
    // JDBC sink connector version (downloaded to init-cdc/kafka-plugins/ by setup-cdc.sh)
    "JDBC_VERSION": "10.7.4",
    // Enable yboutput logical replication plugin for all new tables
    "TSERVER_FLAGS": "ysql_yb_default_replica_identity=DEFAULT",
    // Connector env vars referenced in README curl examples
    "HOST": "127.0.0.1",
    "SRC_USER": "yugabyte",
    "SRC_SECRET": "yugabyte",
    "SRC_DB_OBJECT": "yugabyte",
    "TAR_USER": "postgres",
    "TAR_SECRET": "yugabyte",
    "TAR_DB_OBJECT": "postgres",
    "TOPIC_PREFIX": "sample",
    "SCHEMA": "public"
  },
  "hostRequirements": {
    // Debezium Docker stack (ZK + Kafka + Connect) — much lighter than Confluent Platform
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // Mount the host Docker socket so docker-compose commands work
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  // One-time: install psql client + pv, download demo-magic, pull Debezium images, download connector JARs
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq postgresql-client pv && curl -ssLo init-cdc/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-cdc/pscript init-cdc/prompt.sh && bash .devcontainer/scripts/setup-cdc.sh && echo \"✅ CDC exercise ready\"'",
  // Open workspace before postStartCommand completes so the README
  // is visible while Docker Compose and services start in the background.
  "waitFor": "postCreateCommand",
  // Every start: launch YugabyteDB (with logical replication flag) + Debezium stack
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-cdc.sh && echo \"\" && echo \"▶  Terminal → Run Task → cdc-demo          (guided CDC demo script)\" && echo \"▶  Terminal → Run Task → connector-config   (interactive CDC command shell)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "files.exclude": {
        "ybdb": true,
        "voyager-data": true,
        "init-xcluster": true,
        "init-tablespace": true,
        "init-colocate": true,
        ".devcontainer": true,
        ".github": true,
        "init-clone": true,
        "init-dsql": true,
        "init-ear": true,
        "init-ft": true,
        "init-geo": true,
        "init-obs": true,
        "init-pitr": true,
        "init-privacy": true,
        "init-qt": true,
        "init-rls": true,
        "init-scale": true,
        "init-tt": true,
        "init-voyager-mariadb": true,
        "init-voyager-mysql": true,
        "init-voyager-oracle": true,
        "init-voyager-postgres": true
        }},
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": []
    }
  },
  "forwardPorts": [
    7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000,
    5432,
    2181, 9092, 8083
  ],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" },
    "5432":  { "label": "postgres",       "onAutoForward": "ignore" },
    "2181":  { "label": "zookeeper",      "onAutoForward": "ignore" },
    "9092":  { "label": "kafka-broker",   "onAutoForward": "ignore" },
    "8083":  { "label": "kafka-connect",  "onAutoForward": "notify" }
  },
  "remoteUser": "vscode"
}
