{
  "name": "Change Data Capture — YugabyteDB → PostgreSQL via Debezium",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-cdc",
    // Confluent install location (referenced by start-cdc.sh and user scripts)
    "CONFLUENT_HOME": "${containerWorkspaceFolder}/confluent",
    "KAFKA_VERSION": "7.5.0",
    "KAFKA_CONNECT_PORT": "8083",
    // Connector versions
    "JDBC_VERSION": "10.7.4",
    "POSTGRES_CONNECTOR_VERSION": "2.2.1",
    "YBDB_CONNECTOR_VERSION": "1.9.5.y.220.1",
    // Connector env vars used in README examples
    "SRC_USER": "yugabyte",
    "SRC_SECRET": "yugabyte",
    "SRC_DB_OBJECT": "yugabyte",
    "TAR_USER": "postgres",
    "TAR_SECRET": "yugabyte",
    "TAR_DB_OBJECT": "postgres",
    "MASTERS": "127.0.0.1:7100",
    "TOPIC_PREFIX": "sample",
    "SCHEMA": "public"
  },
  "hostRequirements": {
    // Confluent Platform (ZK + Kafka + SR + Connect + KSQL + CC) is memory-hungry
    "cpus": 8,
    "memory": "16gb",
    "storage": "64gb"
  },
  "features": {
    // Docker-in-Docker for PostgreSQL compose container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    // Java runtime for Confluent Platform
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "jdkDistro": "ms"
    }
  },
  // One-time: download Confluent, install connectors, pull Postgres image
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq postgresql-client && bash .devcontainer/scripts/setup-cdc.sh'",
  // Every start: launch YugabyteDB + PostgreSQL + Confluent
  "postStartCommand": "bash .devcontainer/scripts/start-cdc.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [
    7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000,
    5432,
    2181, 9092, 8081, 8082, 8083, 8088, 9021
  ],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",    "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web",   "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",    "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc",   "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",             "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",     "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",         "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",             "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",         "onAutoForward": "ignore" },
    "5432":  { "label": "postgres",         "onAutoForward": "ignore" },
    "2181":  { "label": "zookeeper",        "onAutoForward": "ignore" },
    "9092":  { "label": "kafka-broker",     "onAutoForward": "ignore" },
    "8081":  { "label": "schema-registry",  "onAutoForward": "ignore" },
    "8082":  { "label": "rest-proxy",       "onAutoForward": "ignore" },
    "8083":  { "label": "kafka-connect",    "onAutoForward": "notify" },
    "8088":  { "label": "ksqldb",           "onAutoForward": "ignore" },
    "9021":  { "label": "control-center",   "onAutoForward": "notify" }
  },
  "remoteUser": "vscode"
}
