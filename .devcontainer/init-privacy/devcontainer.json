{
  "name": "Data Privacy — Column Encryption & Anonymization",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-privacy",
    "SCRIPT_PATH": "init-privacy"
  },
  "hostRequirements": {
    // Single node sufficient: pgcrypto is a YSQL extension, not cluster-specific
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // One-time: install pv + demo-magic
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq pv && curl -ssLo init-privacy/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-privacy/pscript init-privacy/prompt.sh && echo \"✅ Data Privacy exercise ready\"'",
  // Single-node cluster
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 1 && echo \"\" && echo \"▶  Terminal → Run Task → privacy-demo   (guided data privacy demo)\" && echo \"▶  Terminal → Run Task → ysql            (YSQL shell)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "files.exclude": {
        "ybdb": true,
        "voyager-data": true,
        "init-xcluster": true,
        "init-tablespace": true,
        "init-colocate": true,
        ".devcontainer": true,
        ".github": true,
        "init-cdc": true,
        "init-clone": true,
        "init-dsql": true,
        "init-ear": true,
        "init-ft": true,
        "init-geo": true,
        "init-obs": true,
        "init-pitr": true,
        "init-qt": true,
        "init-rls": true,
        "init-scale": true,
        "init-tt": true,
        "init-voyager-mariadb": true,
        "init-voyager-mysql": true,
        "init-voyager-oracle": true,
        "init-voyager-postgres": true
        }},
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": []
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
