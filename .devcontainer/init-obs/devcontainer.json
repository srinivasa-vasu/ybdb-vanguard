{
  "name": "Observability & Performance Diagnosis",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-obs",
    "SCRIPT_PATH": "init-obs"
  },
  "hostRequirements": {
    // 3-node cluster: yb_servers() per-node load, top_level_node_id in ASH, hot-node detection
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // One-time: install pv + demo-magic
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq pv && curl -ssLo init-obs/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-obs/pscript init-obs/prompt.sh init-obs/run-load.sh && echo \"✅ Observability exercise ready\"'",
  // 3-node cluster with ASH at 500ms sampling + query diagnostics enabled
  // setup.sql creates obs_demo, seeds 500k orders, and configures pg_stat_statements
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 3 ysql_yb_enable_ash=true,ysql_yb_ash_sampling_interval_ms=500,ysql_yb_enable_query_diagnostics=true && ysqlsh -f init-obs/setup.sql && echo \"\" && echo \"▶  Terminal → Run Task → run-load    (start background query load)\" && echo \"▶  Terminal → Run Task → ysql-obs    (YSQL shell → obs_demo)\" && echo \"▶  Terminal → Run Task → obs-demo    (guided investigation demo)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "files.exclude": {
        ".devcontainer": true,
        ".github": true,
        "init-cdc": true,
        "init-clone": true,
        "init-dsql": true,
        "init-ear": true,
        "init-ft": true,
        "init-geo": true,
        "init-iloop": true,
        "init-pitr": true,
        "init-privacy": true,
        "init-qt": true,
        "init-rls": true,
        "init-scale": true,
        "init-tt": true,
        "init-voyager-mariadb": true,
        "init-voyager-mysql": true,
        "init-voyager-oracle": true,
        "init-voyager-postgres": true
        }},
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": []
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
