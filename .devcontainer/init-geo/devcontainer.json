{
  "name": "Geo-distribution & Tablespaces",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-geo",
    "SCRIPT_PATH": "init-geo",
    // yb-admin master addresses for all three nodes
    "MASTERS": "127.0.0.1:7100,127.0.0.2:7100,127.0.0.3:7100"
  },
  "hostRequirements": {
    // 3 nodes × separate regions — 4 CPUs is sufficient for a single-machine simulation
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // One-time: install pv + demo-magic
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq pv && curl -ssLo init-geo/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-geo/pscript init-geo/prompt.sh && echo \"✅ Geo-distribution exercise ready\"'",
  // Every start: 3-node multi-region cluster (us-east / eu-west / ap-south)
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-geo.sh && echo \"\" && echo \"▶  Terminal → Run Task → geo-demo   (guided geo-distribution demo)\" && echo \"▶  Terminal → Run Task → ysql        (YSQL shell)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on"
      },
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": [
        {
          // Compound task: opens exercise-specific terminals when the workspace loads.
          // ysql opens separately via its own runOn:folderOpen in the workspace tasks.json.
          "label": "_auto-open",
          "type": "shell",
          "command": "code init-geo/README.md 2>/dev/null || true",
          "dependsOn": ["geo-demo"],
          "dependsOrder": "parallel",
          "runOptions": { "runOn": "folderOpen" },
          "presentation": { "reveal": "never", "panel": "shared" },
          "problemMatcher": []
        }
      ]
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
