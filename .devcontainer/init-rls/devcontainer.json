{
  "name": "Row Level Security & Multi-tenancy",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-rls",
    "SCRIPT_PATH": "init-rls"
  },
  "hostRequirements": {
    // RLS is enforced at the YSQL layer — single node is sufficient
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  // Single-node cluster — RLS is a YSQL-layer feature, node count is irrelevant
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 1 && echo \"\" && echo \"▶  Terminal → Run Task → rls-demo   (guided RLS & multi-tenancy demo)\" && echo \"▶  Terminal → Run Task → ysql        (YSQL shell)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "files.exclude": {
        "ybdb": true,
        "voyager-data": true,
        "init-xcluster": true,
        "init-tablespace": true,
        "init-colocate": true,
        ".devcontainer": true,
        ".github": true,
        "init-cdc": true,
        "init-clone": true,
        "init-dsql": true,
        "init-ear": true,
        "init-ft": true,
        "init-geo": true,
        "init-obs": true,
        "init-pitr": true,
        "init-privacy": true,
        "init-qt": true,
        "init-scale": true,
        "init-tt": true,
        "init-voyager-mariadb": true,
        "init-voyager-mysql": true,
        "init-voyager-oracle": true,
        "init-voyager-postgres": true
        }},
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": []
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
