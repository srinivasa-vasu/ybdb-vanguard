{
  "name": "WSO2 API Manager — Enterprise API Gateway with YugabyteDB",
  "containerEnv": {
    "ART_PATH": "init-wso2",
    "SCRIPT_PATH": "init-wso2",
    "WSO2_VERSION": "4.7.0",
    "MASTERS": "127.0.0.1:7100"
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "hostRequirements": {
    "cpus": 8,
    "memory": "16gb",
    "storage": "32gb"
  },
  "postStartCommand": "bash .devcontainer/scripts/start-wso2.sh && echo '▶  Open terminals:  wso2-demo  →  wso2-ws'",
  "postStopCommand": "docker rm -f wso2-apim 2>/dev/null || true",
  "extraForwardPorts": [9443, 8280, 8243],
  "extraPortsAttributes": {
    "9443": {
      "label": "WSO2 Admin / Publisher / DevPortal (HTTPS)",
      "onAutoForward": "silent",
      "protocol": "https"
    },
    "8280": {
      "label": "WSO2 Gateway (HTTP)",
      "onAutoForward": "silent"
    },
    "8243": {
      "label": "WSO2 Gateway (HTTPS)",
      "onAutoForward": "silent"
    }
  }
}
