{
  "name": "OpenSearch — Log Observability with YugabyteDB",
  "containerEnv": {
    "ART_PATH": "init-opensearch",
    "SCRIPT_PATH": "init-opensearch",
    "OPENSEARCH_VERSION": "3.7.0",
    "OTEL_VERSION": "0.155.0",
    "MASTERS": "127.0.0.1:7100"
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-opensearch.sh && echo \"\" && echo \">> Terminal > Run Task > opensearch-demo   (guided YB observability demo)\" && echo \">> Terminal > Run Task > opensearch-ws     (Workshop shell for manual exercises)\"'",
  "postStopCommand": "docker rm -f opensearch-ybdb opensearch-dashboards-ybdb 2>/dev/null || true",
  "extraForwardPorts": [9200, 5601],
  "extraPortsAttributes": {
    "9200": { "label": "OpenSearch API", "onAutoForward": "silent" },
    "5601": { "label": "OpenSearch Dashboards", "onAutoForward": "notify" },
    "5": { "onAutoForward": "ignore" },
    "920": { "onAutoForward": "ignore" },
    "8888": { "onAutoForward": "ignore" }
  },
  "otherPortsAttributes": {
    "onAutoForward": "ignore"
  }
}
