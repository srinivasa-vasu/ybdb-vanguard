{
  "name": "Voyager — MariaDB → YugabyteDB migration",
  "build": {
    "dockerfile": "../../.ybdb.Dockerfile",
    "context": "../.."
  },
  "runArgs": ["--init"],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-voyager-mariadb",
    "SRC_DB_TYPE": "mysql",
    "SRC_DB_ID": "Chinook",
    "SRC_USER": "root",
    "SRC_SECRET": "yugabyte",
    "TARGET_DB_ID": "yugabyte",
    "TARGET_USER": "yugabyte",
    "TARGET_SECRET": "yugabyte",
    "SCHEMA": "public"
  },
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },
  // Mount the host Docker socket so docker-compose commands work
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  // One-time: install mysql-client (works for MariaDB too), pull image, install yb-voyager
  "postCreateCommand": "bash -c 'sudo apt-get update -qq && sudo apt-get install -y -qq default-mysql-client pv && curl -ssLo init-voyager-mariadb/pscript https://raw.githubusercontent.com/paxtonhare/demo-magic/master/demo-magic.sh && chmod +x init-voyager-mariadb/pscript init-voyager-mariadb/prompt.sh && sudo chmod 666 /var/run/docker.sock 2>/dev/null || true && docker-compose -f init-voyager-mariadb/compose.yml pull && wget -q -O /tmp/yb-voyager https://raw.githubusercontent.com/yugabyte/yb-voyager/main/docker/yb-voyager-docker && chmod +x /tmp/yb-voyager && sudo mv /tmp/yb-voyager /usr/local/bin/yb-voyager && mkdir -p voyager-data && echo \"✅ MariaDB Voyager exercise ready\"'",
  // Open workspace before postStartCommand completes so the README
  // is visible while Docker Compose and services start in the background.
  "waitFor": "postCreateCommand",
  // Every start: launch YugabyteDB + MariaDB
  "postStartCommand": "bash -c 'bash .devcontainer/scripts/start-ybdb.sh 1 && sudo chmod 666 /var/run/docker.sock 2>/dev/null || true && docker-compose -f init-voyager-mariadb/compose.yml up -d && echo \"\" && echo \"▶  Terminal → Run Task → mariadb      (MariaDB source shell)\" && echo \"▶  Terminal → Run Task → yb-voyager   (Voyager migration shell)\"'",
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on"
      },
      "extensions": [
        "ms-azuretools.vscode-docker"
      ],
      "tasks": [
        {
          // Compound task: opens exercise-specific terminals when the workspace loads.
          // ysql opens separately via its own runOn:folderOpen in the workspace tasks.json.
          "label": "_auto-open",
          "type": "shell",
          "command": "code init-voyager-mariadb/README.md 2>/dev/null || true",
          "dependsOn": ["mariadb-demo", "mariadb", "yb-voyager"],
          "dependsOrder": "parallel",
          "runOptions": { "runOn": "folderOpen" },
          "presentation": { "reveal": "never", "panel": "shared" },
          "problemMatcher": []
        }
      ]
    }
  },
  "forwardPorts": [7000, 9000, 7100, 9100, 5433, 15433, 13000, 9042, 12000, 3306],
  "portsAttributes": {
    "7000":  { "label": "yb-master-web",  "onAutoForward": "ignore" },
    "9000":  { "label": "yb-tserver-web", "onAutoForward": "ignore" },
    "7100":  { "label": "yb-master-rpc",  "onAutoForward": "ignore" },
    "9100":  { "label": "yb-tserver-rpc", "onAutoForward": "ignore" },
    "5433":  { "label": "ysql",           "onAutoForward": "ignore" },
    "15433": { "label": "yugabyted-ui",   "onAutoForward": "notify" },
    "13000": { "label": "ysql-api",       "onAutoForward": "ignore" },
    "9042":  { "label": "ycql",           "onAutoForward": "ignore" },
    "12000": { "label": "ycql-api",       "onAutoForward": "ignore" },
    "3306":  { "label": "mariadb",        "onAutoForward": "ignore" }
  },
  "remoteUser": "vscode"
}
