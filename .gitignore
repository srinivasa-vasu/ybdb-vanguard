# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs
hs_err_pid*
replay_pid*

.DS_Store

# ── YugabyteDB cluster data ───────────────────────────────────────────────────
# Written to workspace root by start-ybdb.sh and start-geo.sh at runtime.
ybdb/

# ── Voyager migration export directories ─────────────────────────────────────
# Created by yb-voyager export commands during migration exercises.
voyager-data/

# ── Encryption keys (init-ear) ───────────────────────────────────────────────
# Generated by openssl rand during the EAR exercise. Never commit key files.
init-ear/keys/

# ── Kafka connector plugins (init-cdc) ───────────────────────────────────────
# Downloaded by setup-cdc.sh into a local staging dir before loading into volume.
init-cdc/kafka-plugins/

# ── demo-magic helper script ─────────────────────────────────────────────────
# Downloaded at container creation time; not source-controlled.
**/pscript

# ── Chinook datasets ──────────────────────────────────────────────────────────
# Downloaded from lerocha/chinook-database at postCreateCommand time.
init-voyager-oracle/chinook_data.sql
init-voyager-mysql/chinook_data.sql
init-voyager-mariadb/chinook_data.sql
init-voyager-postgres/chinook_data.sql

# ── devcontainer lock files ───────────────────────────────────────────────────
devcontainer-lock.json
