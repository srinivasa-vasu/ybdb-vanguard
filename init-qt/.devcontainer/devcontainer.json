{
  "name": "ybdb-dev",
  "build": {
    "dockerfile": ".ybdb.Dockerfile"
  },
  "runArgs": [
    "--init"
  ],
  "containerEnv": {
    "DATA_PATH": "ybdb",
    "ART_PATH": "init-qt"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [
    7000,
    9000,
    7100,
    9100,
    5433,
    15433,
    13000,
    9042,
    12000
  ],
  "portsAttributes": {
    "7000": {
      "label": "yb-master-web",
      "onAutoForward": "ignore"
    },
    "9000": {
      "label": "yb-tserver-web",
      "onAutoForward": "ignore"
    },
    "7100": {
      "label": "yb-master-rpc",
      "onAutoForward": "ignore"
    },
    "9100": {
      "label": "yb-tserver-rpc",
      "onAutoForward": "ignore"
    },
    "5433": {
      "label": "ysql",
      "onAutoForward": "ignore"
    },
    "15433": {
      "label": "yugabyted-ui",
      "onAutoForward": "ignore"
    },
    "13000": {
      "label": "ysql-api",
      "onAutoForward": "ignore"
    },
    "9042": {
      "label": "ycql",
      "onAutoForward": "ignore"
    },
    "12000": {
      "label": "ycql-api",
      "onAutoForward": "ignore"
    }
  },
  "remoteUser": "vscode"
}