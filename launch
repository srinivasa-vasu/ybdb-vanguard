# ── ANSI colours ──────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# Role tag colours
_col_dev="$CYAN"
_col_ops="$BLUE"
_col_sre="$YELLOW"
_col_arc="$GREEN"

# ── detect GitHub repo from git remote ───────────────────────────────────────
detect_github_repo() {
  local remote
  remote=$(git remote get-url origin 2>/dev/null || echo "")
  if [[ "$remote" == git@github.com:* ]]; then
    echo "${remote#git@github.com:}" | sed 's/\.git$//'
  elif [[ "$remote" == https://github.com/* ]]; then
    echo "${remote#https://github.com/}" | sed 's/\.git$//'
  else
    echo ""
  fi
}

# ── URL-encode a string (pure bash) ──────────────────────────────────────────
urlencode() {
  local string="$1" encoded="" i c
  for (( i=0; i<${#string}; i++ )); do
    c="${string:i:1}"
    case "$c" in
      [a-zA-Z0-9._~-]) encoded+="$c" ;;
      *) printf -v hex '%%%02X' "'$c"; encoded+="$hex" ;;
    esac
  done
  echo "$encoded"
}

# ── render a row of role tags ─────────────────────────────────────────────────
_render_roles() {
  local tags="$1" out=""
  for tag in $tags; do
    case "$tag" in
      dev) out+="${_col_dev}dev${NC} " ;;
      ops) out+="${_col_ops}ops${NC} " ;;
      sre) out+="${_col_sre}sre${NC} " ;;
      arc) out+="${_col_arc}arc${NC} " ;;
    esac
  done
  echo -en "$out"
}

# ── display menu ──────────────────────────────────────────────────────────────
menu() {
  echo ""
  echo -e "${YELLOW}╔══════════════════════════════════════════════════════╗${NC}"
  echo -e "${YELLOW}║        YugabyteDB Vanguard — Exercise Launcher       ║${NC}"
  echo -e "${YELLOW}╚══════════════════════════════════════════════════════╝${NC}"

  local prev_cat=""
  for i in "${!exercises[@]}"; do
    local cat="${categories[$i]}"
    local dc="${devcontainers[$i]}"
    local link="${links[$i]}"
    local role="${roles[$i]}"
    local res="${resources[$i]}"
    local name="${exercises[$i]}"
    local num=$(( i + 1 ))

    # ── section header when category changes ─────────────────────────────
    if [[ "$cat" != "$prev_cat" ]]; then
      echo ""
      local fill_count=$(( 54 - ${#cat} ))
      (( fill_count < 4 )) && fill_count=4
      local fill
      fill=$(printf '─%.0s' $(seq 1 "$fill_count"))
      echo -e "  ${CYAN}${BOLD}── ${cat} ${fill}${NC}"
      prev_cat="$cat"
    fi

    # ── row: number ───────────────────────────────────────────────────────
    printf "  %3d.  " "$num"

    # ── row: name (fixed 42-char column) ─────────────────────────────────
    printf "%-42s" "$name"

    # ── row: resource warning (fixed 22-char column) ─────────────────────
    # Printf width doesn't count ANSI escapes, so pad manually after printing.
    if [[ -n "$res" ]]; then
      local res_text="⚠ $res"
      printf "${RED}%s${NC}" "$res_text"
      local _pad=$(( 22 - ${#res_text} ))
      (( _pad > 0 )) && printf "%${_pad}s" ""
    else
      printf "%22s" ""
    fi

    # ── row: status / role tags ───────────────────────────────────────────
    if [[ -n "$dc" ]]; then
      _render_roles "$role"
      echo ""
    elif [[ -n "$link" ]]; then
      printf "${DIM}(external)${NC}  "
      _render_roles "$role"
      echo ""
    else
      echo -e "${DIM}(coming soon)${NC}"
    fi
  done

  # ── legend ───────────────────────────────────────────────────────────────
  echo ""
  echo -e "  ${DIM}Tags:  ${_col_dev}dev${NC}${DIM} developer   ${_col_ops}ops${NC}${DIM} operations   ${_col_sre}sre${NC}${DIM} reliability   ${_col_arc}arc${NC}${DIM} architect${NC}"
  echo -e "  ${DIM}⚠ = above standard requirements (default: 4 CPU · 8 GB RAM · 32 GB disk)${NC}"
  echo ""
}

# ── execute selection ─────────────────────────────────────────────────────────
execute() {
  local idx=$(( $1 - 1 ))
  local exercise="${exercises[$idx]}"
  local dc="${devcontainers[$idx]}"
  local link="${links[$idx]}"

  echo ""

  # ── external repo ─────────────────────────────────────────────────────────
  if [[ -z "$dc" && -n "$link" ]]; then
    echo -e "${GREEN}External repository — open in your browser:${NC}"
    echo ""
    echo -e "  ${CYAN}${link}${NC}"
    echo ""
    return
  fi

  # ── coming soon ───────────────────────────────────────────────────────────
  if [[ -z "$dc" ]]; then
    echo -e "${RED}This exercise is not yet available.${NC}"
    return
  fi

  # ── devcontainer exercise ─────────────────────────────────────────────────
  local dc_path=".devcontainer/${dc}/devcontainer.json"
  local github_repo
  github_repo=$(detect_github_repo)

  echo -e "${BOLD}${exercise}${NC}"
  echo -e "  Devcontainer: ${DIM}${dc_path}${NC}"
  [[ -n "${resources[$idx]}" ]] && \
    echo -e "  Resources:    ${RED}⚠  ${resources[$idx]}${NC}"
  echo ""

  if [[ -n "$github_repo" ]]; then
    local encoded_path
    encoded_path=$(urlencode "$dc_path")
    local codespace_url="https://codespaces.new/${github_repo}?devcontainer_path=${encoded_path}"

    echo -e "${GREEN}▶  GitHub Codespaces${NC}"
    echo -e "   ${CYAN}${codespace_url}${NC}"
    echo ""
    echo -e "${GREEN}▶  DevPod${NC}"
    echo -e "   ${CYAN}devpod up . --devcontainer-path ${dc_path}${NC}"
    echo ""
    echo -e "${GREEN}▶  VS Code Dev Containers${NC}"
    echo -e "   ${DIM}Command Palette → Dev Containers: Open Folder in Container → pick config${NC}"
    echo ""

    if command -v gh &>/dev/null; then
      echo -e "${YELLOW}Create Codespace directly with the GitHub CLI:${NC}"
      echo -e "   ${CYAN}gh codespace create --repo ${github_repo} --devcontainer-path ${dc_path}${NC}"
      echo ""
      read -rp "  Create now with gh CLI? [y/N] " confirm
      if [[ "$confirm" =~ ^[Yy]$ ]]; then
        gh codespace create \
          --repo "$github_repo" \
          --devcontainer-path "$dc_path" \
          --display-name "$exercise"
      fi
    fi
  else
    echo -e "${YELLOW}No GitHub remote detected.${NC}"
    echo -e "Push this repo to GitHub first, then:"
    echo ""
    echo -e "${GREEN}▶  GitHub Codespaces${NC}"
    echo -e "   ${DIM}https://codespaces.new → select devcontainer manually${NC}"
    echo ""
    echo -e "${GREEN}▶  DevPod (local)${NC}"
    echo -e "   ${CYAN}devpod up . --devcontainer-path ${dc_path}${NC}"
    echo ""
    echo -e "${GREEN}▶  VS Code Dev Containers (local)${NC}"
    echo -e "   ${DIM}Command Palette → Dev Containers: Open Folder in Container${NC}"
    echo ""
  fi
}

# ── sanity checks ─────────────────────────────────────────────────────────────
_len=${#exercises[@]}
if [[ "$_len" -ne "${#devcontainers[@]}" ]] || \
   [[ "$_len" -ne "${#links[@]}"        ]] || \
   [[ "$_len" -ne "${#categories[@]}"   ]] || \
   [[ "$_len" -ne "${#roles[@]}"        ]] || \
   [[ "$_len" -ne "${#resources[@]}"    ]]; then
  echo -e "${RED}[Internal error]: All registry arrays must have the same length.${NC}"
  exit 1
fi

# ── main loop ─────────────────────────────────────────────────────────────────
while true; do
  menu

  read -rp "Enter the number of the exercise (0 to exit): " choice

  if ! [[ "$choice" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Please enter a number between 0 and ${_len}.${NC}"
    continue
  fi

  if [[ "$choice" -eq 0 ]]; then
    echo -e "${YELLOW}Goodbye!${NC}"
    break
  elif [[ "$choice" -ge 1 && "$choice" -le "$_len" ]]; then
    execute "$choice"
  else
    echo -e "${RED}Invalid selection. Please choose a number between 1 and ${_len}.${NC}"
  fi
done
