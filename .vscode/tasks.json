        "reveal": "always",
        "panel": "dedicated",
        "group": "voyager-postgres",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Import shell ──────────────────────────────────────────────────────────
    {
      "label": "yb-voyager-import",
      "detail": "Open the Voyager import shell (import schema + data) (init-voyager-postgres)",
      "type": "shell",
      "command": "echo '📥 yb-voyager-import — run import schema / import data commands here' && exec bash",
