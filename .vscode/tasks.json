        "reveal": "always",
        "panel": "dedicated",
        "group": "voyager-postgres",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Write-ahead / cutover shell ───────────────────────────────────────────
    {
      "label": "yb-voyager-wa",
      "detail": "Open the Voyager cutover shell (migration report / cutover / end migration) (init-voyager-postgres)",
