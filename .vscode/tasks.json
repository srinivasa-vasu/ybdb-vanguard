{
  // VS Code tasks for all exercises in ybdb-vanguard.
  //
  // Launch from the Terminal menu → Run Task, or use the keyboard shortcut
  // (default: Ctrl+Shift+P → "Tasks: Run Task" to pick any task).
  //
  // Each task opens in its own dedicated terminal panel, matching the shell
  // names referenced in the exercise READMEs.
  "version": "2.0.0",
  "tasks": [

    // ═══════════════════════════════════════════════════════════════════════
    // Auto-open on folder load  (runOn: folderOpen — workspace-level so VS Code
    // reliably triggers these; devcontainer tasks do not guarantee folderOpen)
    // ═══════════════════════════════════════════════════════════════════════

    {
      // Opens the exercise-specific README when the workspace loads.
      // ${workspaceFolder} and ${env:ART_PATH} are proper VS Code task variables
      // (unlike ${PWD} which VS Code may resolve to empty before the shell sees it).
      // ART_PATH is set per-exercise in each devcontainer's containerEnv.
      "label": "_open-readme",
      "type": "shell",
      "command": "code \"${workspaceFolder}/${env:ART_PATH}/README.md\"",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": { "reveal": "never", "panel": "shared", "close": true, "showReuseMessage": false },
      "problemMatcher": []
    },

    // ═══════════════════════════════════════════════════════════════════════
    // Housekeeping
    // ═══════════════════════════════════════════════════════════════════════

    {
      "label": "clean",
      "detail": "Stop YugabyteDB + Docker Compose stacks, remove all runtime data (ybdb/, voyager-data/, keys, pscript files)",
      "type": "shell",
      "command": "bash -c 'echo \"🛑 Stopping YugabyteDB nodes...\" && yugabyted destroy --base_dir=ybdb/ybd1 2>/dev/null; yugabyted destroy --base_dir=ybdb/ybd2 2>/dev/null; yugabyted destroy --base_dir=ybdb/ybd3 2>/dev/null; yugabyted destroy --base_dir=ybdb/source 2>/dev/null; yugabyted destroy --base_dir=ybdb/target 2>/dev/null; echo \"🐳 Stopping Docker Compose stacks...\" && for f in init-cdc/compose.yml init-voyager-postgres/compose.yml init-voyager-mysql/compose.yml init-voyager-mariadb/compose.yml init-voyager-oracle/compose.yml; do [ -f \"$f\" ] && docker-compose -f \"$f\" down --remove-orphans 2>/dev/null || true; done; echo \"🐳 Stopping ecosystem containers...\" && docker rm -f keycloak-ybdb kong-gateway wso2-apim opensearch-ybdb opensearch-dashboards-ybdb 2>/dev/null || true; echo \"🧹 Removing runtime data...\" && rm -rf ybdb voyager-data init-ear/keys init-cdc/kafka-plugins init-voyager-postgres/voyager-data init-voyager-mysql/voyager-data init-voyager-mariadb/voyager-data init-voyager-oracle/voyager-data && find . -name pscript -not -path \"./.git/*\" -delete && echo \"✅ All runtime data removed and services stopped.\"'",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },


