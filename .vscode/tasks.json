      "type": "shell",
      "command": "[ '${env:ART_PATH}' = 'init-ear' ] || exit 0; cd init-ear && echo '🔐 ear-demo  —  Encryption at Rest' && echo '   Run when ready: bash prompt.sh' && exec bash",
      
