    // ═══════════════════════════════════════════════════════════════════════

    // ── psql source shell ─────────────────────────────────────────────────────
    {
      "label": "psql",
      "detail": "Open a psql session against the source PostgreSQL database (init-voyager-postgres)",
      "type": "shell",
      // PGHOST / PGUSER / PGPASSWORD are set by the devcontainer env
      "command": "psql",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "voyager-postgres",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },

    // ── Export shell ──────────────────────────────────────────────────────────
    {
      "label": "yb-voyager-export",
      "detail": "Open the Voyager export shell (assess / export schema + data) (init-voyager-postgres)",
      "type": "shell",
      "command": "echo '📤 yb-voyager-export — run assess-migration / export schema / export data commands here' && exec bash",
